# ==============================================================================
# Django HTMX Starter - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# In development, start.sh will prompt for missing values interactively.
# In production, all required values must be set before starting.
# ==============================================================================

# ------------------------------------------------------------------------------
# Project Configuration
# ------------------------------------------------------------------------------

# Display name for your project (shown in templates)
PROJECT_NAME=My Django Project

# Django secret key (auto-generated on first dev run if empty)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# ------------------------------------------------------------------------------
# Social Authentication (Optional)
# ------------------------------------------------------------------------------

# Set to 'true' to enable Google OAuth authentication
ENABLE_SOCIAL_AUTH=false

# Google OAuth credentials (required if ENABLE_SOCIAL_AUTH=true)
# Get these from: https://console.developers.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Production Only
# ------------------------------------------------------------------------------

# Comma-separated list of allowed hosts (required in production)
# Example: myapp.example.com,www.myapp.example.com
DJANGO_ALLOWED_HOSTS=
